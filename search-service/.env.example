# Copy this to .env and fill in values

# Shared secret — must match VECTOR_SEARCH_SECRET in Next.js .env.local
VECTOR_SEARCH_SECRET=eclat_search_secret_2026

# Supabase (for reindex route — fetches live products)
SUPABASE_URL=https://tlxjgvnuchefkgjxlgeq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ChromaDB storage path (relative to search-service/)
CHROMA_DATA_PATH=./chroma_data

# ChromaDB collection name
CHROMA_COLLECTION=eclat_products

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Server
HOST=0.0.0.0
PORT=8000

# Minimum semantic similarity to be considered a confident result
CONFIDENCE_THRESHOLD=0.40
